# =============================================================================
# Telegram Trading Signals Bot - Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Telegram (required)
# -----------------------------------------------------------------------------
# Create a bot via @BotFather, then get your chat ID (e.g. from @userinfobot).
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# -----------------------------------------------------------------------------
# TradingView Webhook (required for incoming alerts)
# -----------------------------------------------------------------------------
# Port the webhook server will listen on. Use 5000 for local; 80/443 for VPS.
WEBHOOK_PORT=5000
# Optional: bind host (0.0.0.0 to accept external connections)
WEBHOOK_HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Coinglass API (optional - for liquidation signals)
# -----------------------------------------------------------------------------
# Get your API key from https://www.coinglass.com/user
# Leave empty to disable liquidation polling.
COINGLASS_API_KEY=
# Exchanges and pairs to check (comma-separated). Format: exchange:pair
# Example: Binance:BTCUSDT,Binance:ETHUSDT
COINGLASS_SYMBOLS=Binance:BTCUSDT,Binance:ETHUSDT
# Poll interval in seconds (min 60 to stay within limits).
COINGLASS_POLL_INTERVAL=60

# -----------------------------------------------------------------------------
# Signal thresholds (customize your Buy/Sell logic)
# -----------------------------------------------------------------------------
# RSI: oversold = potential buy, overbought = potential sell
RSI_OVERSOLD=30
RSI_OVERBOUGHT=70
# MACD: positive crossover = buy signal, negative = sell (handled by webhook payload)
# Liquidation: spike threshold in USD - alert when 1h liquidation exceeds this
LIQUIDATION_SPIKE_USD=5000000
# Minimum cooldown (seconds) between alerts for the same asset+trigger to avoid spam
ALERT_COOLDOWN_SECONDS=300

# -----------------------------------------------------------------------------
# Anti-spam and limits
# -----------------------------------------------------------------------------
# Max number of alerts per minute (across all triggers)
MAX_ALERTS_PER_MINUTE=10
# Enable/disable each signal source (true/false)
ENABLE_TRADINGVIEW_WEBHOOK=true
ENABLE_COINGLASS_LIQUIDATION=true
